# Free Dispatcher token server — copy to .env and fill in.
# From developers.zello.com (create a free account, register an app):
ZELLO_ISSUER=your-issuer-from-developers-zello-com
# Paste the RSA private key. Either a real multi-line key, or a single line
# with literal \n between lines (the server converts \n back to newlines).
ZELLO_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
PORT=3001
